# ⚠️  WARNING: This .env file contains secrets!
# ⚠️  NEVER commit this file to version control!
# ⚠️  Use .env.example as a template instead
#
# For production, use environment variables from:
# - AWS Secrets Manager
# - HashiCorp Vault
# - GitHub Secrets
# - Docker/Kubernetes Secrets
#
# See .env.example for configuration template

# LOCAL DEVELOPMENT ONLY
# Replace with actual values when deploying

POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=suqafuran_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/suqafuran_db

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_DB=0

SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=525600
REFRESH_TOKEN_EXPIRE_DAYS=7

SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_USER=your-email@domain.com
SMTP_PASSWORD=your-email-password
SMTP_TLS=false
SMTP_SSL=true
EMAILS_FROM_EMAIL=noreply@suqafuran.com
EMAILS_FROM_NAME=Suqafuran
EMAILS_ENABLED=true
EMAIL_VERIFICATION_EXPIRE_HOURS=24

RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:5173
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,gif,webp
UPLOAD_DIR=./uploads

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

AFRICASTALKING_USERNAME=your_username
AFRICASTALKING_API_KEY=your_api_key
AFRICASTALKING_SENDER_ID=SUQAFURAN

ENVIRONMENT=development
GRAFANA_PASSWORD=your_grafana_password

LIPANA_SECRET_KEY=your_lipana_secret_key
LIPANA_WEBHOOK_SECRET=your_lipana_webhook_secret

RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=noreply@suqafuran.com

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_TOPIC_BUSINESS_EVENTS=suqafuran-business-events

MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_BUSINESS_SHORTCODE=174379
MPESA_PASSKEY=your_mpesa_passkey
MPESA_ENVIRONMENT=sandbox
MPESA_CALLBACK_URL=http://localhost:8000/api/v1/payments/mpesa/callback
