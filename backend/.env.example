# ⚠️  WARNING: This is a TEMPLATE file
# DO NOT commit real secrets to version control!
# Copy to .env and fill in your actual values
# .env is ignored by git (.gitignore)

# DATABASE
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=suqafuran_db
POSTGRES_PORT=5432
DATABASE_URL=sqlite:///./suqafuran.db

# REDIS
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# JWT & SECURITY
SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=525600

# EMAIL
RESEND_API_KEY=your_resend_api_key_here
EMAILS_FROM_EMAIL=noreply@suqafuran.com
EMAILS_FROM_NAME=Suqafuran

# SMS
AFRICASTALKING_USERNAME=your_username
AFRICASTALKING_API_KEY=your_api_key_here
AFRICASTALKING_SENDER_ID=SUQAFURAN

# M-PESA
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_BUSINESS_SHORTCODE=your_shortcode
MPESA_PASSKEY=your_passkey
MPESA_ENVIRONMENT=sandbox
MPESA_CALLBACK_URL=http://localhost:8000/api/v1/payments/mpesa/callback

# APP
ENVIRONMENT=development
DEBUG=True
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
APP_NAME=Suqafuran API
APP_VERSION=1.0.0
