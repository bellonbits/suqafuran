# Suqafuran Backend Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
POSTGRES_SERVER=your-postgres-host.com
POSTGRES_USER=postgres_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=suqafuran_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://user:password@localhost:5432/suqafuran_db

# ============================================================================
# REDIS CACHE
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
SECRET_KEY=your_random_secret_key_here_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=525600
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_USER=your_email@domain.com
SMTP_PASSWORD=your_email_password
SMTP_TLS=false
SMTP_SSL=true
EMAILS_FROM_EMAIL=noreply@suqafuran.com
EMAILS_FROM_NAME=Suqafuran
EMAILS_ENABLED=true
EMAIL_VERIFICATION_EXPIRE_HOURS=24

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://yourdomain.com
COOKIE_SECURE=true
COOKIE_SAMESITE=strict

# ============================================================================
# FILE UPLOAD
# ============================================================================
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,gif,webp
UPLOAD_DIR=./uploads

# ============================================================================
# OAUTH - SOCIAL LOGIN
# ============================================================================
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ============================================================================
# SMS & NOTIFICATIONS
# ============================================================================
AFRICASTALKING_USERNAME=your_username
AFRICASTALKING_API_KEY=your_api_key
AFRICASTALKING_SENDER_ID=SUQAFURAN
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=noreply@suqafuran.com

# ============================================================================
# PAYMENT PROCESSING
# ============================================================================
LIPANA_SECRET_KEY=your_lipana_secret_key
LIPANA_WEBHOOK_SECRET=your_lipana_webhook_secret
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_BUSINESS_SHORTCODE=174379
MPESA_PASSKEY=your_mpesa_passkey
MPESA_ENVIRONMENT=production
MPESA_CALLBACK_URL=https://yourdomain.com/api/v1/payments/mpesa/callback

# ============================================================================
# MEDIA STORAGE
# ============================================================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================================================
# AI & ANALYTICS
# ============================================================================
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# ============================================================================
# MESSAGE STREAMING
# ============================================================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_TOPIC_BUSINESS_EVENTS=suqafuran-business-events

# ============================================================================
# ENVIRONMENT
# ============================================================================
ENVIRONMENT=production
GRAFANA_PASSWORD=your_grafana_password
LOG_LEVEL=INFO
