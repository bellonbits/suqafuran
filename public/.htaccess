# ══════════════════════════════════════════════════════════════════════════════
#  Cache Strategy — Suqafuran
#
#  Rule of thumb:
#    • Files with a content hash in the name  → cache forever (immutable)
#    • Files without a hash (SW, manifest, HTML, JSON) → never cache
# ══════════════════════════════════════════════════════════════════════════════

# ── 1. NEVER cache index.html ─────────────────────────────────────────────────
<Files "index.html">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires "0"
</Files>

# ── 2. NEVER cache the service worker or workbox runtime ──────────────────────
#    If sw.js is cached the browser won't detect new deploys for up to a year.
<FilesMatch "^(sw\.js|workbox-[^.]+\.js)$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires "0"
  Header set Service-Worker-Allowed "/"
</FilesMatch>

# ── 3. NEVER cache the PWA manifest or JSON files ────────────────────────────
<FilesMatch "\.(webmanifest|json)$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires "0"
</FilesMatch>

# ── 4. Cache hashed Vite assets forever ──────────────────────────────────────
#    Vite names every chunk/asset with a content hash (e.g. index-btZfkqnt.js)
#    new hash = new filename = browsers always fetch fresh files after deploy.
<FilesMatch "assets/.*\.[a-f0-9]{8,}\.(js|css|woff2?|ttf|eot|svg|png|jpg|jpeg|gif|ico|webp)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# ── 5. Short cache for unhashed static assets ─────────────────────────────────
<FilesMatch "\.(woff2?|ttf|eot|otf|png|jpg|jpeg|gif|ico|webp)$">
  Header set Cache-Control "public, max-age=86400, stale-while-revalidate=3600"
</FilesMatch>

# ── SPA Routing ───────────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Skip real files and directories
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Route everything else to index.html
  RewriteRule ^ index.html [QSA,L]
</IfModule>

# ── Gzip compression ─────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE application/manifest+json
  AddOutputFilterByType DEFLATE font/woff2 image/svg+xml
</IfModule>

# ── Security headers ─────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
